TOPIC=inteligencia artificial
TOPIC_KEYWORDS=ai,openai,deep learning,machine learning,regulation

# Frequência por execução (o workflow agenda 2 execuções por dia)
POSTS_PER_RUN=1
MAX_ARTICLES=40
LOOKBACK_HOURS=48

# IA para seleção/sumarização (opcional, mas recomendada)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Credenciais do X (obrigatórias para publicar)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Segurança para validar sem publicar
DRY_RUN=true

